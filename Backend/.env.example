# Server Configuration
PORT=5000

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017/ecommerce

# JWT Configuration
ACCESS_TOKEN_PRIVATE_KEY=your-access-token-secret-key-change-in-production
ACCESS_TOKEN_PUBLIC_KEY=your-access-token-public-key
REFRESH_TOKEN_PEIVATE_KEY=your-refresh-token-secret-key-change-in-production
REFRESH_TOKEN_PUBLIC_KEY=your-refresh-token-public-key
ACCESS_TOKEN_EXPIRE_DATE=15m
REFRESH_TOKEN_EXPIRE_DATE=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:4000

# Environment
NODE_ENV=development
